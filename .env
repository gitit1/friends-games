# ──────────────────────────────────────────────────────────────────────────
# Developer flags (Vite reads VITE_* at startup — restart `npm run dev`
# after changing anything here).
# ──────────────────────────────────────────────────────────────────────────

# Touch / kiosk lock. When 'true', the app aggressively blocks the browser's
# default touch behaviour on a tablet: no focus stealing, no text selection,
# no pinch / double-tap zoom, no scroll / pull-to-refresh, no ghost mouse
# clicks. Buttons keep working.
#
# This ONLY takes effect in developer mode (npm run dev). A production build
# (vite build) always ignores it, so it can never reach the live site even if
# left 'true' here. Flip true/false and restart the dev server to toggle.
VITE_TOUCH_LOCK=false
